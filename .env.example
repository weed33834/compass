# Compass 环境变量模板
# 用法：cp .env.example .env && 编辑敏感字段
# Docker 部署：docker compose 会自动读取同目录的 .env

# ============ 数据库（必填）============
# PostgreSQL 连接串。Docker 部署时由 docker-compose 自动拼接，无需手动填
# 本地开发：postgresql://用户名:密码@localhost:5432/数据库名?schema=public
DATABASE_URL="postgresql://compass:changeme@localhost:5432/compass?schema=public"

# Docker Compose 专用变量（本地开发可忽略）
POSTGRES_USER=compass
POSTGRES_PASSWORD=changeme   # 生产环境必须改为强密码
POSTGRES_DB=compass
APP_PORT=3000

# ============ NextAuth（必填）============
# 站点对外访问 URL（生产环境改为实际域名）
NEXTAUTH_URL=http://localhost:3000

# JWT 签名密钥，必须为强随机串
# 生成方式：openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# ============ 邮件（可选，用于忘记密码）============
# SMTP 连接串，格式：smtp://user:pass@host:port?security=tls
# 未配置时"忘记密码"功能不可用，注册/登录不受影响
SMTP_URL=

# ============ OAuth 登录（可选）============
# GitHub OAuth App：https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=
# Google OAuth：https://console.cloud.google.com/apis/credentials
GOOGLE_ID=
GOOGLE_SECRET=
# 启用哪些 OAuth 入口（逗号分隔，如 "github,google"）。留空则不显示 OAuth 按钮
NEXT_PUBLIC_OAUTH_PROVIDERS=

# ============ 安全（生产环境推荐配置）============
# 可信反向代理 IP（逗号分隔）。部署在 Caddy/Nginx 后时填写代理 IP，用于正确提取客户端 IP 做限流
# 未配置时：开发环境信任所有代理头；生产环境仅信任直连 IP（可能影响限流精度）
# 示例：TRUSTED_PROXY_IPS=127.0.0.1,10.0.0.0/8
TRUSTED_PROXY_IPS=

# ============ 其他（可选）============
# 站点名称（用于邮件模板等）
APP_NAME=Compass
